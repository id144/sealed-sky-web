# Sealed Sky — environment variables
#
# Copy this file to `.env.local` and fill in the values. Vite picks up
# `VITE_*` variables at build time.
#
# The app works fully without any of these — they only enable the optional
# ENS subdomain publishing for the "Most Creative Use of ENS" path.

# ── NameStone (Phase 2 — ENS subdomain publishing) ─────────────────────────
# Sign up at https://namestone.com, register a parent domain, copy the API
# key. The integration silently disables itself if either var is missing.
VITE_NAMESTONE_API_KEY=
VITE_NAMESTONE_DOMAIN=sealed-sky.eth
